# Copy to terraform.tfvars and fill in the values.
# terraform.tfvars is gitignored — never commit real values.

aws_region  = "us-east-1"
environment = "prod"
app_name    = "security-spring"  # rename to your service name

# Networking
availability_zones = ["us-east-1a", "us-east-1b"]

# ECS Fargate
ecr_image_tag     = "latest"
app_cpu           = 512
app_memory        = 1024
app_desired_count = 2
app_min_count     = 1
app_max_count     = 5

# RDS
db_instance_class        = "db.t3.micro"
db_name                  = "security"
db_username              = "appuser"
db_multi_az              = false
db_backup_retention_days = 7

# Redis
redis_node_type = "cache.t3.micro"

# ALB / HTTPS
# Obtain a certificate via ACM (Certificate Manager) and paste the ARN here
acm_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# S3
avatar_bucket_force_destroy = false
