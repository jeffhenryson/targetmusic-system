# =============================================================================
# security-spring - Variáveis de Ambiente
# Copie este arquivo para .env para desenvolvimento local (nunca commite o .env)
# =============================================================================

# --- Perfil da aplicação ---
# Valores: dev | hml | prod
SPRING_PROFILES_ACTIVE=dev

# --- JWT ---
# Chave secreta para assinar tokens JWT (mínimo 256-bit / 32 chars para HS256)
JWT_SECRET=troque-para-uma-chave-segura-de-256-bits-em-producao
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# --- Banco de dados (obrigatório para perfis hml/prod) ---
DB_URL=jdbc:postgresql://localhost:5432/security
DB_USERNAME=postgres
DB_PASSWORD=postgres

# --- CORS ---
# Em dev o padrão já é permissivo (*); restrinja em hml/prod
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type

# --- Rate limiting de login ---
LOGIN_RATE_WINDOW_SECONDS=60
LOGIN_RATE_MAX_REQUESTS=10

# --- Lockout por usuário ---
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_DURATION_MINUTES=15

# --- Email (Resend) ---
# Obtenha sua API key em https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=Sistema <noreply@seudominio.com>
EMAIL_VERIFICATION_TTL_MINUTES=15
EMAIL_VERIFICATION_FRONTEND_URL=https://seudominio.com/auth/verify-email

# --- OAuth2 Google ---
# Obtenha em https://console.cloud.google.com/apis/credentials (tipo: Aplicativo da Web)
# Necessário no perfil hml — sem isso o HmlStartupValidator bloqueia a inicialização
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# --- Scheduler ---
# Cron para limpeza de refresh tokens (padrao: 03:00 diario)
REFRESH_TOKEN_CLEANUP_CRON=0 0 3 * * *
