# Dev profile - in-memory H2 and developer conveniences
spring.flyway.enabled=false
spring.datasource.url=jdbc:h2:mem:demo;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE
spring.datasource.driverClassName=org.h2.Driver
spring.datasource.username=sa

spring.jpa.hibernate.ddl-auto=create-drop
spring.jpa.show-sql=true
spring.jpa.open-in-view=false

spring.h2.console.enabled=true
spring.h2.console.path=/h2-console

# JWT (dev) - use env to override in real use
jwt.secret=${JWT_SECRET:dev-secret-please-change-to-256-bit-random-key}
jwt.access-ttl-minutes=${JWT_ACCESS_TTL_MINUTES:15}
jwt.refresh-ttl-days=${JWT_REFRESH_TTL_DAYS:7}
jwt.issuer=${JWT_ISSUER:security-spring}
jwt.audience=${JWT_AUDIENCE:api}

# CORS (dev permissivo - override via env se necessario)
cors.allowed-origins=${CORS_ALLOWED_ORIGINS:*}
cors.allowed-methods=${CORS_ALLOWED_METHODS:GET,POST,PUT,DELETE,OPTIONS,PATCH}
cors.allowed-headers=${CORS_ALLOWED_HEADERS:*}
# allow-credentials=false em dev para compatibilidade com allowedOrigins("*")
# Para ativar cookies HttpOnly em dev, trocar CORS_ALLOWED_ORIGINS para http://localhost:4200
cors.allow-credentials=${CORS_ALLOW_CREDENTIALS:false}

# Cookie de refresh: não-Secure em dev (HTTP)
cookie.secure=${COOKIE_SECURE:false}

# Actuator exposure in dev
management.endpoints.web.exposure.include=health,info,metrics
management.endpoint.health.probes.enabled=true
management.endpoint.health.show-details=always

# Login rate limiting (dev)
rate.limit.login.window-seconds=${LOGIN_RATE_WINDOW_SECONDS:60}
rate.limit.login.max-requests=${LOGIN_RATE_MAX_REQUESTS:10}

# Excluir autoconfiguration de Redis em dev — os adaptadores Redis têm @Profile("hml","prod")
# mas sem essa exclusão o Spring Boot ainda tenta criar RedisConnectionFactory.
spring.autoconfigure.exclude=\
  org.springframework.boot.autoconfigure.data.redis.RedisAutoConfiguration,\
  org.springframework.boot.autoconfigure.data.redis.RedisRepositoriesAutoConfiguration

# Desabilitar health checks de infra que nao existem em dev
management.health.redis.enabled=false

# Em dev nao ha proxy reverso: nao confiar em X-Forwarded-For enviado pelo cliente
server.forward-headers-strategy=none

# Lockout por usuário (dev)
auth.lockout.max-attempts=${AUTH_LOCKOUT_MAX_ATTEMPTS:5}
auth.lockout.duration-minutes=${AUTH_LOCKOUT_DURATION_MINUTES:15}

# Limite de sessões ativas simultâneas por usuário (0 = sem limite)
auth.max-sessions-per-user=${AUTH_MAX_SESSIONS_PER_USER:5}

# Email verification (dev) — TTL em minutos e cooldown de reenvio em segundos
email.verification.ttl-minutes=${EMAIL_VERIFICATION_TTL_MINUTES:15}
email.verification.resend-cooldown-seconds=${EMAIL_RESEND_COOLDOWN_SECONDS:60}

# Email provider: 'logging' = loga no console (padrão dev), 'resend' = envia de verdade.
# Para testar envio real: defina EMAIL_PROVIDER=resend e RESEND_API_KEY=<sua-chave>.
email.provider=${EMAIL_PROVIDER:logging}
resend.api-key=${RESEND_API_KEY:dev-placeholder-key}
resend.from=${RESEND_FROM:noreply@example.com}
email.verification.subject=${EMAIL_VERIFICATION_SUBJECT:Código de confirmação de cadastro}

# Scheduler (dev) — roda às 03:00 todos os dias
refresh-token.cleanup.cron=${REFRESH_TOKEN_CLEANUP_CRON:0 0 3 * * *}

# Seed (dev) — sobrescreva via variáveis de ambiente para não commitar credenciais
seed.admin.password=${SEED_ADMIN_PASSWORD:Admin@dev1}
seed.user.password=${SEED_USER_PASSWORD:User@dev1}
# seed.dev.email vazio = usuário DEV não é criado. Defina DEV_EMAIL para habilitar.
seed.dev.email=${DEV_EMAIL:}
seed.dev.password=${DEV_PASSWORD:Dev@secure1!}

# Roles atribuídas automaticamente no auto-registro (/auth/register).
# Vazio = sem role automática (princípio do mínimo privilégio).
# Exemplo: auth.registration.default-roles=ROLE_USER
auth.registration.default-roles=${AUTH_REGISTRATION_DEFAULT_ROLES:}

# Password reset
password-reset.ttl-minutes=${PASSWORD_RESET_TTL_MINUTES:15}
password-reset.frontend-url=${PASSWORD_RESET_FRONTEND_URL:http://localhost:3000/reset-password}

# 2FA / TOTP
# ATENÇÃO: gere uma chave real com: openssl rand -base64 32 (deve ter 32 bytes = 256 bits)
totp.encryption.key=${TOTP_ENCRYPTION_KEY:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=}
totp.app-name=${TOTP_APP_NAME:security-spring}
